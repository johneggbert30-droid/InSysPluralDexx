# Copy this file to .env and fill in the values before starting the server.

# Port the API listens on (Render sets this automatically)
PORT=3000

# Secret used to sign JWT tokens – use a long random string in production
JWT_SECRET=change-this-before-deploying

# Comma-separated list of allowed front-end origins for CORS
# e.g. https://yourusername.github.io
FRONTEND_ORIGIN=
